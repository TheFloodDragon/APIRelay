server:
  host: 0.0.0.0
  port: 8080
  mode: release
  
  # 静态文件服务（前端）
  static_path: ./web/dist
  
database:
  type: sqlite
  path: ./data/apirelay.db

redis:
  enabled: false
  host: localhost
  port: 6379
  password: ""
  db: 0

auth:
  # 管理后台访问密钥（请修改为强密码）
  admin_key: change-me-in-production
  
  # 是否需要登录
  require_login: false
  
  # JWT密钥（如果启用登录）
  jwt_secret: your-secret-key

# 默认调度策略
scheduler:
  strategy: priority  # priority, weighted, random, round_robin
  health_check_interval: 60
  unhealthy_threshold: 3
  
# 限流配置
rate_limit:
  enabled: false
  global: 1000
  per_key: 60

# 日志配置
logging:
  level: info
  format: json
  output: file
  file: ./logs/apirelay.log
  max_size: 100
  max_backups: 10
  max_age: 30
  request_log: true

# 监控
monitoring:
  prometheus:
    enabled: false
    path: /metrics

# CORS配置
cors:
  enabled: true
  allow_origins:
    - "*"
  allow_methods:
    - GET
    - POST
    - PUT
    - DELETE
  allow_headers:
    - "*"
